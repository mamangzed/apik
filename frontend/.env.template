# APIK Frontend Environment Template
# Copy this file to .env and fill in your values

# Clerk Authentication (optional - app works in guest mode without this)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# API Connection URLs
# Leave empty to use relative paths (same origin as frontend)
VITE_APP_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:2611
VITE_WS_BASE_URL=ws://localhost:2611

# For production docker-compose builds, set these build-time ARGs:
# export VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
# export VITE_APP_BASE_URL=https://your-domain.example
# export VITE_API_BASE_URL=https://your-domain.example
# export VITE_WS_BASE_URL=wss://your-domain.example
